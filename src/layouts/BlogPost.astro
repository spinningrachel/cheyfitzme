---
import Base from './Base.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  toc?: { slug: string; text: string; depth: number }[];
}

const { post, toc } = Astro.props;
const { title, description, pubDate } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Related posts: other posts, up to 3
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .filter(p => p.id !== post.id)
  .slice(0, 3);
---

<Base title={title} description={description}>
  <div class="article-wrap">

    <!-- ARTICLE -->
    <article class="article">
      <div class="article__inner">

        <!-- back link -->
        <a href="/blog/" class="article__back">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back to the Playbook
        </a>

        <!-- header -->
        <div class="article__eyebrow t-label">The PMM Playbook</div>
        <h1 class="article__title">{title}</h1>
        <p class="article__lede">{description}</p>

        <!-- byline -->
        <div class="article__byline">
          <div class="article__avatar" aria-hidden="true">RC</div>
          <div class="article__meta">
            <strong>Rachel Cheyfitz</strong>
            <span class="article__sep" aria-hidden="true">·</span>
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          </div>
        </div>

        <!-- feature image slot -->
        <div class="article__image" aria-hidden="true">
          <span class="article__image-label">feature image</span>
        </div>

        <!-- table of contents -->
        {toc && toc.length > 0 && (
          <div class="article__toc">
            <div class="article__toc-label t-label">In this piece</div>
            <ol class="article__toc-list">
              {toc.map((item, i) => (
                <li class="article__toc-item">
                  <span class="article__toc-num">{String(i + 1).padStart(2, '0')}</span>
                  <a class="article__toc-text" href={`#${item.slug}`}>{item.text}</a>
                </li>
              ))}
            </ol>
          </div>
        )}

        <!-- body -->
        <div class="article__body prose">
          <slot />
        </div>

        <!-- author card -->
        <div class="article__author">
          <div class="article__author-avatar" aria-hidden="true">RC</div>
          <div class="article__author-text">
            <p><strong>Rachel Cheyfitz</strong> builds positioning frameworks and the documentation underneath them — for deep tech, dev tools, and the occasional beard-cream brand. Not just solving the problem in front of you; fixing the reason it keeps happening.</p>
            <a href="/lets-meet/" class="article__author-link">Work with me</a>
          </div>
        </div>

      </div>
    </article>

    <!-- RELATED -->
    {allPosts.length > 0 && (
      <section class="related">
        <div class="related__inner">
          <div class="related__header">
            <h2 class="related__heading">Keep reading</h2>
            <a href="/blog/" class="related__all">All posts</a>
          </div>
          <div class="related__list">
            {allPosts.map(p => (
              <a href={`/blog/${p.id}`} class="related__row">
                <span class="related__row-title">{p.data.title}</span>
                <span class="related__row-date">
                  {p.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- NEWSLETTER BAND -->
    <section class="newsletter-band">
      <div class="newsletter-band__glow" aria-hidden="true"></div>
      <div class="newsletter-band__inner">
        <div class="newsletter-band__copy">
          <div class="newsletter-band__eyebrow t-label">The PMM Playbook</div>
          <h2 class="newsletter-band__heading">Get the next one in your inbox.</h2>
          <p class="newsletter-band__sub">Double opt-in, one-click unsubscribe, and I never use your address for anything else. That's the whole deal.</p>
        </div>
        <form class="newsletter-band__form" action="#" method="post">
          <input
            type="email"
            name="email"
            placeholder="your email address"
            class="newsletter-band__input"
            required
            aria-label="Email address"
          />
          <button type="submit" class="btn btn-voltage newsletter-band__btn">Subscribe</button>
        </form>
      </div>
    </section>

  </div>
</Base>

<style is:global>
  /* ─── ARTICLE WRAP ─────────────────────────────────── */
  .article-wrap {
    --article-max: 980px;
    --body-max: 700px;
  }

  /* ─── ARTICLE ──────────────────────────────────────── */
  .article {
    padding: 76px var(--pad-page) 80px;
  }

  .article__inner {
    max-width: var(--article-max);
    margin: 0 auto;
  }

  .article__back {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 14px;
    font-weight: 600;
    color: var(--c-muted-soft);
    margin-bottom: 34px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .article__back:hover { color: var(--c-ink); }

  .article__eyebrow {
    color: var(--c-cyan-electric);
    margin-bottom: 24px;
  }

  .article__title {
    font-size: clamp(42px, 4.8vw, 64px);
    font-weight: 800;
    line-height: 0.97;
    letter-spacing: -2.6px;
    color: var(--c-ink);
    margin: 0 0 28px;
    max-width: 15ch;
    text-wrap: balance;
  }

  .article__lede {
    font-size: 24px;
    line-height: 1.4;
    color: var(--c-body);
    max-width: 30ch;
    margin: 0 0 40px;
    font-weight: 500;
  }

  .article__byline {
    display: flex;
    align-items: center;
    gap: 13px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--c-hairline);
    max-width: var(--body-max);
  }

  .article__avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #EAF4FB;
    border: 1px solid #dcebf5;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'BioRhyme', serif;
    font-weight: 700;
    font-size: 15px;
    color: var(--c-cyan-deep);
    flex-shrink: 0;
  }

  .article__meta {
    font-size: 15px;
    color: var(--c-body);
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .article__meta strong {
    color: var(--c-ink);
  }

  .article__sep {
    color: var(--c-faint);
  }

  .article__image {
    margin: 40px 0 8px;
    aspect-ratio: 16/7;
    border-radius: 14px;
    background: #EAF4FB;
    border: 1px solid #dcebf5;
    display: flex;
    align-items: flex-end;
    padding: 22px;
    max-width: var(--article-max);
  }

  .article__image-label {
    font-size: 13px;
    color: #7fb4d8;
    font-style: italic;
  }

  /* ─── TABLE OF CONTENTS ───────────────────────────── */
  .article__toc {
    max-width: var(--body-max);
    margin: 44px 0 0;
    padding: 22px 0;
    border-top: 1px solid var(--c-hairline);
    border-bottom: 1px solid var(--c-hairline);
  }

  .article__toc-label {
    color: var(--c-muted-soft);
    margin-bottom: 18px;
  }

  .article__toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .article__toc-item {
    display: flex;
    align-items: baseline;
    gap: 18px;
  }

  .article__toc-num {
    font-family: 'BioRhyme', serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--c-cyan-electric);
    flex-shrink: 0;
    line-height: 1;
  }

  .article__toc-text {
    font-size: 18px;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.3px;
    line-height: 1.2;
    text-decoration: none;
    transition: color 0.15s;
  }
  .article__toc-text:hover {
    color: var(--c-purple-royal);
  }

  /* ─── PROSE BODY ───────────────────────────────────── */
  .article__body {
    max-width: var(--body-max);
    margin-top: 44px;
  }

  .prose p {
    font-size: 20px;
    line-height: 1.75;
    color: #3a2a52;
    margin: 0 0 28px;
  }

  .prose strong {
    color: var(--c-ink);
  }

  .prose em {
    font-style: italic;
  }

  /* Section headings — BioRhyme numeral + Schibsted heading */
  .prose h2,
  .prose h3 {
    font-weight: 800;
    font-size: 32px;
    letter-spacing: -1.4px;
    color: var(--c-ink);
    margin: 52px 0 8px;
    line-height: 1.03;
    scroll-margin-top: 24px;
  }

  /* Counter: auto-number h2/h3 headings with BioRhyme numeral */
  .prose {
    counter-reset: section;
  }

  .prose h2::before,
  .prose h3::before {
    counter-increment: section;
    content: "0" counter(section);
    font-family: 'BioRhyme', serif;
    font-weight: 700;
    font-size: 28px;
    color: var(--c-cyan-electric);
    margin-right: 14px;
    letter-spacing: 0;
  }

  .prose h4 {
    font-size: 20px;
    font-weight: 700;
    color: var(--c-ink);
    margin: 32px 0 8px;
    letter-spacing: -0.4px;
  }

  .prose ul,
  .prose ol {
    margin: 0 0 28px;
    padding-left: 1.4em;
  }

  .prose li {
    font-size: 20px;
    line-height: 1.7;
    color: #3a2a52;
    margin-bottom: 10px;
  }

  .prose blockquote {
    font-size: 32px;
    line-height: 1.22;
    letter-spacing: -1.1px;
    font-weight: 500;
    color: var(--c-ink);
    margin: 44px 0;
    padding: 0;
    border: none;
    max-width: 19ch;
  }

  .prose blockquote::before {
    display: block;
    font-family: 'BioRhyme', serif;
    font-size: 84px;
    line-height: 0.5;
    color: var(--c-cyan-electric);
    height: 44px;
    content: '\201C';
    margin-bottom: 16px;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--c-hairline);
    margin: 48px 0;
  }

  /* Inline table of contents — if the MD has a specific block */
  .prose .toc {
    margin: 0 0 48px;
    padding: 22px 0;
    border-top: 1px solid var(--c-hairline);
    border-bottom: 1px solid var(--c-hairline);
  }

  /* ─── AUTHOR ───────────────────────────────────────── */
  .article__author {
    max-width: var(--body-max);
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--c-hairline);
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .article__author-avatar {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 50%;
    background: #EAF4FB;
    border: 1px solid #dcebf5;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'BioRhyme', serif;
    font-weight: 700;
    font-size: 20px;
    color: var(--c-cyan-deep);
  }

  .article__author-text p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--c-body);
    margin: 0 0 12px;
  }

  .article__author-text strong {
    color: var(--c-ink);
  }

  .article__author-link {
    font-size: 15px;
    font-weight: 600;
    color: var(--c-purple-ink);
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-color: var(--c-cyan-electric);
  }
  .article__author-link:hover {
    color: var(--c-purple-royal);
  }

  /* ─── RELATED ──────────────────────────────────────── */
  .related {
    padding: 8px var(--pad-page) 64px;
  }

  .related__inner {
    max-width: var(--article-max);
    margin: 0 auto;
  }

  .related__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .related__heading {
    font-weight: 800;
    font-size: 24px;
    letter-spacing: -0.8px;
    color: var(--c-ink);
    margin: 0;
  }

  .related__all {
    font-size: 15px;
    font-weight: 600;
    color: var(--c-purple-ink);
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-color: var(--c-cyan-electric);
  }

  .related__list {
    border-top: 1px solid var(--c-hairline);
  }

  .related__row {
    display: flex;
    align-items: baseline;
    gap: 24px;
    padding: 22px 0;
    border-bottom: 1px solid var(--c-hairline);
    text-decoration: none;
    color: inherit;
  }
  .related__row:hover .related__row-title {
    color: var(--c-purple-royal);
  }

  .related__row-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.4px;
    color: var(--c-ink);
    flex: 1;
    transition: color 0.15s;
  }

  .related__row-date {
    font-size: 14px;
    color: var(--c-muted-soft);
    flex-shrink: 0;
  }

  /* ─── NEWSLETTER BAND ──────────────────────────────── */
  .newsletter-band {
    background: linear-gradient(180deg, #5A00A3 0%, #2A0048 100%);
    padding: 72px var(--pad-page);
    position: relative;
    overflow: hidden;
  }

  .newsletter-band__glow {
    position: absolute;
    top: -60px;
    right: -40px;
    width: 340px;
    height: 340px;
    background: radial-gradient(circle, rgba(40,183,255,0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  .newsletter-band__inner {
    max-width: var(--article-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .newsletter-band__eyebrow {
    color: var(--c-cyan-electric);
    margin-bottom: 16px;
  }

  .newsletter-band__heading {
    font-weight: 800;
    font-size: clamp(30px, 3.4vw, 40px);
    line-height: 1.0;
    letter-spacing: -1.6px;
    color: var(--c-white);
    margin: 0 0 14px;
    max-width: 16ch;
  }

  .newsletter-band__sub {
    font-size: 16px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.72);
    margin: 0;
    max-width: 46ch;
  }

  .newsletter-band__form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .newsletter-band__input {
    flex: 1;
    min-width: 200px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 9px;
    height: 52px;
    padding: 0 18px;
    font-size: 15px;
    color: var(--c-white);
    font-family: 'Schibsted Grotesk', sans-serif;
    outline: none;
  }

  .newsletter-band__input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }

  .newsletter-band__input:focus {
    border-color: rgba(255, 255, 255, 0.6);
  }

  .newsletter-band__btn {
    height: 52px;
    padding: 0 28px;
    font-size: 15px;
  }

  /* ─── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 900px) {
    .newsletter-band__inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 640px) {
    .article {
      padding: 48px var(--pad-page) 56px;
    }

    .article__title {
      letter-spacing: -1.8px;
    }

    .article__lede {
      font-size: 20px;
    }

    .prose h2,
    .prose h3 {
      font-size: 26px;
    }

    .prose p,
    .prose li {
      font-size: 18px;
    }

    .prose blockquote {
      font-size: 24px;
    }

    .article__image {
      aspect-ratio: 4/3;
    }
  }
</style>
