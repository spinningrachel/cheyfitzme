---
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  register?: 'plain' | 'voltage' | 'twilight';
}

const {
  title,
  description = 'Marketing strategist, advisor and mentor. Positioning frameworks and GTM strategy for tech companies.',
  ogImage = '/og-default.png',
  register = 'plain',
} = Astro.props;

const siteTitle = title === 'Home'
  ? 'Rachel Cheyfitz — Marketing Strategist, Advisor & Mentor'
  : `${title} — Rachel Cheyfitz`;
---

<!doctype html>
<html lang="en" data-register={register}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{siteTitle}</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}favicon.svg`} />
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}styles/global.css`} />
    <!-- Google Search Console -->
    <meta name="google-site-verification" content="Gt-GLF6IJqpJtUqJ-QBczrnPvIBe5i_TUFSqF8B7r9Q" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Y3GEEMEDRZ"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Y3GEEMEDRZ');
    </script>
    <!-- Senja testimonials widget -->
    <script src="https://widget.senja.io/widget/fedd2b18-c443-4f91-b547-b6753c030625/platform.js" type="text/javascript" async></script>
  </head>
  <body class="site-wrap">
    <SiteNav />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <!-- Cal.com floating button -->
    <script type="text/javascript">
      (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
      Cal("init", "meetgreet", {origin:"https://app.cal.com"});
      Cal.ns.meetgreet("floatingButton", {"calLink":"cheyfitz/meetgreet","config":{"layout":"month_view","useSlotsViewOnSmallScreen":"true"},"buttonColor":"#5A00A3","buttonTextColor":"#73E800","buttonText":"Let's Meet"});
      Cal.ns.meetgreet("ui", {"cssVarsPerTheme":{"light":{"cal-brand":"#5A00A3"},"dark":{"cal-brand":"#73E800"}},"hideEventTypeDetails":false,"layout":"month_view"});
    </script>
  </body>
</html>
