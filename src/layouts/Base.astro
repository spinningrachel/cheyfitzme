---
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  register?: 'plain' | 'voltage' | 'twilight';
}

const {
  title,
  description = 'Marketing strategist, advisor and mentor. Positioning frameworks and GTM strategy for tech companies.',
  ogImage = '/og-default.png',
  register = 'plain',
} = Astro.props;

const siteTitle = title === 'Home'
  ? 'Rachel Cheyfitz — Marketing Strategist, Advisor & Mentor'
  : `${title} — Rachel Cheyfitz`;
---

<!doctype html>
<html lang="en" data-register={register}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{siteTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body class="site-wrap">
    <SiteNav />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
