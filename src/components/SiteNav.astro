---
const navLinks = [
  { label: 'Amplify your message', href: '/core-positioning/' },
  { label: 'Marketing resources',  href: '/marketing-resources/' },
  { label: 'Events',               href: '/events/' },
  { label: 'Mentoring',            href: '/get-help-free/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-nav">
  <nav class="site-nav__inner">
    <a href="/" class="site-nav__logo" aria-label="Rachel Cheyfitz — home">
      <img
        src="/logos/cheyfitz-logo-lockup-horizontal.svg"
        alt="Rachel Cheyfitz"
        height="26"
        width="auto"
      />
    </a>

    <ul class="site-nav__links">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['site-nav__link', { 'is-active': currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/lets-meet/" class="btn btn-ink site-nav__cta">
          Let's meet
        </a>
      </li>
    </ul>

    <button class="site-nav__burger" aria-label="Open menu" aria-expanded="false">
      <img src="/icons/menu.svg" alt="" width="20" height="20" aria-hidden="true" />
    </button>
  </nav>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--c-white);
    border-bottom: 1px solid var(--c-hairline-soft);
  }

  .site-nav__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--pad-page);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .site-nav__logo img {
    display: block;
    height: 26px;
    width: auto;
  }

  .site-nav__links {
    display: flex;
    align-items: center;
    gap: 26px;
  }

  .site-nav__link {
    font-size: 15px;
    font-weight: 500;
    color: var(--c-ink);
    text-decoration: none;
    transition: color 0.15s;
  }
  .site-nav__link:hover,
  .site-nav__link.is-active {
    color: var(--c-purple-royal);
  }

  .site-nav__cta {
    font-size: 14px;
    padding: 10px 18px;
  }

  .site-nav__burger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  @media (max-width: 768px) {
    .site-nav__links {
      display: none;
    }
    .site-nav__burger {
      display: flex;
    }
  }
</style>
