---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const portfolio = (await getCollection('portfolio')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Portfolio" description="Work samples across cybersecurity, dev tools, telematics, recruitment, and more.">
  <section class="portfolio-hero">
    <div class="portfolio-inner">
      <p class="t-label eyebrow">Work samples</p>
      <h1 class="portfolio-headline">Portfolio</h1>
      <p class="portfolio-lede">A selection of deliverables across cybersecurity, developer tools, telematics, and more.</p>
    </div>
  </section>

  <section class="portfolio-list-section">
    <div class="portfolio-inner">
      {portfolio.map(item => (
        <div class="portfolio-row">
          <span class="t-mono item-category">{item.data.category}</span>
          <a href={`/portfolio/${item.id}`} class="item-title">{item.data.title}</a>
          <span class="item-client">{item.data.client}</span>
          <p class="item-desc">{item.data.description}</p>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .portfolio-hero {
    padding: 88px var(--pad-page) 56px;
  }

  .portfolio-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .eyebrow {
    color: var(--c-muted);
    margin-bottom: 20px;
  }

  .portfolio-headline {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 800;
    color: var(--c-ink);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0 0 20px;
  }

  .portfolio-lede {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: 18px;
    color: var(--c-body);
    max-width: 560px;
    line-height: 1.6;
    margin: 0;
  }

  .portfolio-list-section {
    padding: 0 var(--pad-page) 96px;
    border-top: 1px solid var(--c-hairline);
  }

  .portfolio-row {
    border-bottom: 1px solid var(--c-hairline-soft);
    padding: 28px 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .item-category {
    font-size: 12px;
    color: var(--c-muted);
    letter-spacing: 0.04em;
  }

  .item-title {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--c-ink);
    text-decoration: none;
    line-height: 1.25;
  }

  .item-title:hover {
    text-decoration: underline;
  }

  .item-client {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: 14px;
    color: var(--c-muted-soft);
  }

  .item-desc {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: 15px;
    color: var(--c-body);
    line-height: 1.55;
    margin: 0;
  }
</style>
