---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Amplify Your Message"
  description="Is your software business struggling to communicate a unified message? A strong positioning framework is your secret weapon for marketing success."
>

  <section class="page-hero">
    <div class="inner">
      <span class="t-label">Positioning</span>
      <h1>Amplify Your Message</h1>
      <p class="lede">Is your software business struggling to communicate a unified message? A strong positioning framework is your secret weapon for marketing success.</p>
    </div>
  </section>

  <section class="content-section">
    <div class="inner">
      <h2>Why a positioning framework matters</h2>
      <div class="audience-grid">

        <div class="audience-group">
          <h3>Executive Leadership</h3>
          <ul>
            <li>Uniform Messaging</li>
            <li>Smooth Onboarding</li>
            <li>Strategic Alignment</li>
          </ul>
        </div>

        <div class="audience-group">
          <h3>Product Management</h3>
          <ul>
            <li>Strategy Communication</li>
            <li>Roadmap Alignment</li>
            <li>Release Management</li>
          </ul>
        </div>

        <div class="audience-group">
          <h3>Marketing &amp; Growth Leaders</h3>
          <ul>
            <li>Strategy Design</li>
            <li>Execution Support</li>
            <li>Analyst Relations</li>
          </ul>
        </div>

        <div class="audience-group">
          <h3>Your Brand</h3>
          <ul>
            <li>Awareness and recognition</li>
            <li>Consistency</li>
            <li>Efficiency</li>
          </ul>
        </div>

        <div class="audience-group">
          <h3>Your Business</h3>
          <ul>
            <li>Onboarding</li>
            <li>Employee retainment</li>
            <li>Accelerated growth &amp; reduced Sales costs</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="inner two-col">
      <div>
        <h2>Core components</h2>
        <ul class="plain-list">
          <li>ICP</li>
          <li>IPP</li>
          <li>Personas</li>
          <li>Relevant Verticals</li>
          <li>Company Trust</li>
          <li>Brand Overview</li>
          <li>Product Name and Category</li>
          <li>Target Customer Segmentation</li>
          <li>Compelling Reasons to Buy</li>
          <li>Competitive Alternatives</li>
          <li>Differentiated Features</li>
          <li>Value Proposition</li>
          <li>Messaging Guidance and Guidelines</li>
        </ul>
      </div>
      <div>
        <h2>Positioning services</h2>
        <ul class="plain-list">
          <li>ICP/IPP research and formation</li>
          <li>Persona profiles</li>
          <li>Market research/gaps/needs analysis</li>
          <li>Competitive analysis</li>
          <li>Messaging recommendations</li>
          <li>Positioning and messaging documentation</li>
          <li>Positioning and messaging templates</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="inner">
      <h2>Express services</h2>
      <div class="express-list">

        <a class="express-item" href="https://www.fiverr.com/s/jj5b5VL" target="_blank" rel="noopener">
          <div class="express-item__name">SEO Boost</div>
          <div class="express-item__desc">Up to 500 words per topic, focused on your differentiators.</div>
        </a>

        <a class="express-item" href="https://www.fiverr.com/rachelcheyfitz/write-beautiful-landing-product-and-service-pages-for-you" target="_blank" rel="noopener">
          <div class="express-item__name">Website content for conversions</div>
          <div class="express-item__desc">SEO-friendly pages aligned to your brand voice.</div>
        </a>

        <a class="express-item" href="https://www.fiverr.com/s/pdAK0yE" target="_blank" rel="noopener">
          <div class="express-item__name">UX Microcopy</div>
          <div class="express-item__desc">UI content that guides users while reflecting your tone of voice.</div>
        </a>

        <a class="express-item" href="https://www.fiverr.com/rachelcheyfitz/write-outstanding-tailored-technical-and-marketing-content" target="_blank" rel="noopener">
          <div class="express-item__name">Technical &amp; Product Documentation</div>
          <div class="express-item__desc">User-friendly docs for SaaS, software, and tech products.</div>
        </a>

      </div>
    </div>
  </section>

  <section class="content-section cta-section">
    <div class="inner">
      <a href="/lets-meet/" class="btn btn-ink">Let's meet — it's free</a>
    </div>
  </section>

</Base>

<style>
  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--pad-page);
  }

  .page-hero {
    padding: 88px 0;
    border-bottom: 1px solid var(--c-hairline-soft);
  }

  .page-hero .t-label {
    display: block;
    margin-bottom: 1rem;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--c-ink);
    line-height: 1.1;
    margin: 0 0 1.5rem;
  }

  .lede {
    font-size: 1.2rem;
    color: var(--c-body);
    max-width: 680px;
    line-height: 1.6;
    margin: 0;
  }

  .content-section {
    padding: 88px 0;
    border-top: 1px solid var(--c-hairline-soft);
  }

  .content-section h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--c-ink);
    margin: 0 0 2.5rem;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 3rem;
  }

  .audience-group h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-ink);
    margin: 0 0 0.75rem;
  }

  .audience-group ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .audience-group ul li {
    color: var(--c-body);
    padding: 0.35rem 0;
    font-size: 0.95rem;
    border-bottom: 1px solid var(--c-hairline-soft);
  }

  .audience-group ul li:last-child {
    border-bottom: none;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .plain-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .plain-list li {
    color: var(--c-body);
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--c-hairline-soft);
    font-size: 0.95rem;
  }

  .plain-list li:last-child {
    border-bottom: none;
  }

  .express-list {
    display: flex;
    flex-direction: column;
  }

  .express-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--c-hairline-soft);
    text-decoration: none;
    color: inherit;
  }

  .express-item:first-child {
    border-top: 1px solid var(--c-hairline-soft);
  }

  .express-item:hover .express-item__name {
    color: var(--c-purple-royal);
  }

  .express-item__name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--c-ink);
    transition: color 0.15s;
  }

  .express-item__desc {
    font-size: 0.9rem;
    color: var(--c-body);
  }

  .cta-section {
    padding-top: 64px;
    padding-bottom: 88px;
  }

  @media (max-width: 768px) {
    .audience-grid {
      grid-template-columns: 1fr;
    }

    .two-col {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
