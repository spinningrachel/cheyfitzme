---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title="PMM Playbook Blog" description="Insights on product marketing, positioning, technical writing, and more.">
  <section class="blog-hero">
    <div class="blog-inner">
      <p class="t-label eyebrow">PMM Playbook</p>
      <h1 class="blog-headline">The Blog</h1>
      <p class="blog-lede">Insights for product marketers, technical writers, and anyone building in tech.</p>
    </div>
  </section>

  <section class="post-list-section">
    <div class="blog-inner">
      {posts.map(post => (
        <div class="post-row">
          <time class="t-mono post-date" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <a href={`/blog/${post.id}`} class="post-title">{post.data.title}</a>
          <p class="post-desc">{post.data.description}</p>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .blog-hero {
    padding: 88px var(--pad-page) 56px;
  }

  .blog-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .eyebrow {
    color: var(--c-pink-hot);
    margin-bottom: 20px;
  }

  .blog-headline {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 800;
    color: var(--c-ink);
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0 0 20px;
  }

  .blog-lede {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: 18px;
    color: var(--c-body);
    max-width: 520px;
    line-height: 1.6;
    margin: 0;
  }

  .post-list-section {
    padding: 0 var(--pad-page) 96px;
    border-top: 1px solid var(--c-hairline);
  }

  .post-row {
    border-bottom: 1px solid var(--c-hairline-soft);
    padding: 28px 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .post-date {
    font-size: 12px;
    color: var(--c-muted);
    letter-spacing: 0.04em;
  }

  .post-title {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--c-ink);
    text-decoration: none;
    line-height: 1.25;
  }

  .post-title:hover {
    text-decoration: underline;
  }

  .post-desc {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-size: 15px;
    color: var(--c-body);
    line-height: 1.55;
    margin: 0;
  }
</style>
