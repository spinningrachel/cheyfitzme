---
import Base from '../layouts/Base.astro';
---

<Base title="Let's Meet" description="Let's meet, brainstorm, network, and maybe decide to work together. This meeting is at no charge.">

  <section class="meet-hero">
    <div class="meet-hero__inner">
      <h1 class="meet-hero__h1">Let's meet.</h1>
      <p class="meet-hero__lede">Let's take an opportunity to meet, learn about each other, brainstorm, network, drink coffee — and maybe decide to work together too. <strong>This meeting is at no charge.</strong></p>
    </div>
  </section>

  <section class="meet-calendar">
    <div class="meet-calendar__inner">
      <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline"></div>
    </div>
  </section>

  <script type="text/javascript">
    (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
    Cal("init", "meetgreet", {origin:"https://cal.com"});
    Cal.ns.meetgreet("inline", {
      elementOrSelector:"#my-cal-inline",
      config: {"layout":"month_view"},
      calLink: "cheyfitz/meetgreet",
    });
    Cal.ns.meetgreet("ui", {"cssVarsPerTheme":{"light":{"cal-brand":"#53157a"},"dark":{"cal-brand":"#f9d648"}},"hideEventTypeDetails":false,"layout":"month_view"});
  </script>

  <section class="meet-contact">
    <div class="meet-contact__inner">
      <div class="t-label meet-contact__eyebrow">Or reach me directly</div>
      <div class="meet-contact__rows">
        <a href="mailto:rachel@cheyfitz.me" class="meet-contact__row">
          <span class="t-mono meet-contact__key">email</span>
          <span class="meet-contact__val">rachel@cheyfitz.me</span>
        </a>
        <a href="tel:+972509706244" class="meet-contact__row">
          <span class="t-mono meet-contact__key">phone</span>
          <span class="meet-contact__val">+972-50-9706244</span>
        </a>
        <a href="https://www.linkedin.com/in/rachelcheyfitz/" target="_blank" rel="noopener" class="meet-contact__row">
          <span class="t-mono meet-contact__key">linkedin</span>
          <span class="meet-contact__val">linkedin.com/in/rachelcheyfitz</span>
        </a>
        <a href="https://www.fiverr.com/rachelcheyfitz" target="_blank" rel="noopener" class="meet-contact__row">
          <span class="t-mono meet-contact__key">fiverr</span>
          <span class="meet-contact__val">fiverr.com/rachelcheyfitz</span>
        </a>
      </div>
    </div>
  </section>

</Base>

<style>
  .meet-hero {
    padding: 88px var(--pad-page) 64px;
    border-bottom: 1px solid var(--c-hairline-soft);
  }

  .meet-hero__inner {
    max-width: 600px;
    margin: 0 auto 0 0;
    max-width: var(--max-width);
  }

  .meet-hero__h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 800;
    letter-spacing: -3px;
    color: var(--c-ink);
    margin: 0 0 20px;
  }

  .meet-hero__lede {
    font-size: 20px;
    line-height: 1.5;
    color: var(--c-body);
    max-width: 48ch;
    margin: 0;
  }

  .meet-calendar {
    padding: 64px var(--pad-page);
  }

  .meet-calendar__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .meet-contact {
    padding: 0 var(--pad-page) 96px;
    border-top: 1px solid var(--c-hairline-soft);
  }

  .meet-contact__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-top: 56px;
  }

  .meet-contact__eyebrow {
    color: var(--c-muted);
    margin-bottom: 24px;
  }

  .meet-contact__rows {
    display: flex;
    flex-direction: column;
    max-width: 480px;
  }

  .meet-contact__row {
    display: flex;
    gap: 24px;
    align-items: baseline;
    padding: 16px 0;
    border-bottom: 1px solid var(--c-hairline-soft);
    text-decoration: none;
    color: inherit;
  }

  .meet-contact__row:last-child {
    border-bottom: none;
  }

  .meet-contact__row:hover .meet-contact__val {
    color: var(--c-purple-royal);
  }

  .meet-contact__key {
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--c-muted);
    min-width: 60px;
  }

  .meet-contact__val {
    font-size: 16px;
    font-weight: 500;
    color: var(--c-ink);
    transition: color 0.15s;
  }
</style>
