---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Resources I Recommend"
  description="My roundup of the resources I recommend for product marketing, content marketing, and technical writing. Couldn't find it on my site? Try these."
>

  <section class="page-hero">
    <div class="inner">
      <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}marketing-resources/`} class="back-link">← Marketing Resources</a>
      <span class="t-label">Resources I Recommend</span>
      <h1>Couldn't find it here? Try these.</h1>
      <p class="lede">A curated list of the resources I point people to for product marketing, content marketing, and technical writing. I don't own these — I just think they're genuinely good.</p>
    </div>
  </section>

  <section class="resources-section">
    <div class="inner">

      <div class="resource-group">
        <h2 class="resource-group__heading">Product Marketing</h2>

        <a class="resource-row" href="https://www.productmarketingalliance.com/" target="_blank" rel="noopener">
          <div class="resource-row__name">Product Marketing Alliance</div>
          <p class="resource-row__desc">The #1 professional network for product marketers. Research, frameworks, community, and career development. If you're building a PMM career or a PMM team, this is the baseline.</p>
          <span class="resource-row__link">productmarketingalliance.com →</span>
        </a>

        <a class="resource-row" href="https://thepmmcollective.com/collaborative-knowledge-hub/" target="_blank" rel="noopener">
          <div class="resource-row__name">PMM Collective Knowledge Hub</div>
          <p class="resource-row__desc">A community-built reference for product marketers. Crowdsourced frameworks, templates, and real-world examples from practitioners. More practitioner-forward than analyst-forward.</p>
          <span class="resource-row__link">thepmmcollective.com →</span>
        </a>
      </div>

    </div>
  </section>

  <section class="suggest-section">
    <div class="inner">
      <h2>Know something I should add?</h2>
      <p>If there's a resource you think belongs here — a community, a newsletter, a framework, a tool — I'm open to hearing about it. Reach out.</p>
      <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}contact/`} class="btn btn-ink">Get in touch</a>
    </div>
  </section>

</Base>

<style>
  .inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--pad-page);
  }

  .back-link {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--c-muted-soft);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--c-ink); }

  .page-hero {
    padding: 72px 0 64px;
    border-bottom: 1px solid var(--c-hairline-soft);
  }

  .page-hero .t-label {
    display: block;
    color: var(--c-pink-hot);
    margin-bottom: 16px;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--c-ink);
    line-height: 1.05;
    letter-spacing: -1.5px;
    margin: 0 0 1.25rem;
  }

  .lede {
    font-size: 18px;
    color: var(--c-body);
    max-width: 54ch;
    line-height: 1.6;
    margin: 0;
  }

  .resources-section {
    padding: 64px 0 80px;
  }

  .resource-group {
    border-top: 1px solid var(--c-hairline-soft);
    padding-top: 40px;
  }

  .resource-group__heading {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    font-family: 'BioRhyme', serif;
    color: var(--c-muted);
    margin: 0 0 32px;
  }

  .resource-row {
    display: block;
    padding: 28px 0;
    border-bottom: 1px solid var(--c-hairline-soft);
    text-decoration: none;
    color: inherit;
  }

  .resource-row:first-of-type {
    border-top: 1px solid var(--c-hairline-soft);
  }

  .resource-row__name {
    font-size: 20px;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.3px;
    margin-bottom: 8px;
    transition: color 0.15s;
  }

  .resource-row:hover .resource-row__name {
    color: var(--c-purple-royal);
  }

  .resource-row__desc {
    font-size: 15px;
    line-height: 1.65;
    color: var(--c-body);
    margin: 0 0 10px;
    max-width: 66ch;
  }

  .resource-row__link {
    font-size: 13px;
    font-weight: 600;
    color: var(--c-cyan-deep);
    font-family: 'JetBrains Mono', monospace;
  }

  .suggest-section {
    padding: 64px 0 96px;
    background: var(--c-surface);
  }

  .suggest-section h2 {
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 800;
    color: var(--c-ink);
    letter-spacing: -1px;
    margin: 0 0 14px;
  }

  .suggest-section p {
    font-size: 17px;
    line-height: 1.6;
    color: var(--c-body);
    max-width: 50ch;
    margin: 0 0 32px;
  }
</style>
