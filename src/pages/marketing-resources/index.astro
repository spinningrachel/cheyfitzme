---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Base title="Marketing Resources" description="The PMM Stack, the Playbook, events, and free mentoring. The resources I wish I had had.">

  <section class="resources-hero">
    <div class="resources-hero__inner">
      <div class="t-label resources-hero__eyebrow">Marketing resources</div>
      <h1 class="resources-hero__h1">The resources I wish I had had.</h1>
      <p class="resources-hero__lede">The PMM Stack, the Playbook, curated external resources, and free mentoring. Built for product marketers and technical writers who are figuring it out without a roadmap.</p>
    </div>
  </section>

  <section class="resources-grid">
    <div class="resources-grid__inner">

      <a href="/blog/" class="resources-block">
        <div class="resources-block__num t-mono">01</div>
        <h2 class="resources-block__title">PMM Playbook: The Blog</h2>
        <p class="resources-block__body">Positioning, GTM, documentation, PLG, and hiring — written from inside the work, not above it.</p>
        <div class="resources-block__recent">
          {posts.map(post => (
            <div class="resources-block__post">
              <span class="t-mono resources-block__date">
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </span>
              <span class="resources-block__post-title">{post.data.title}</span>
            </div>
          ))}
        </div>
        <span class="resources-block__link">Read the blog →</span>
      </a>

      <div class="resources-block">
        <div class="resources-block__num t-mono">02</div>
        <h2 class="resources-block__title">The PMM Stack</h2>
        <p class="resources-block__body">Tools I actually use — reviewed honestly. Figma Make, Napkin, Granola, and more.</p>
        <div class="resources-block__tools">
          <div class="resources-block__tool-row">
            <span class="t-mono resources-block__tool-name">Napkin</span>
            <span class="resources-block__tool-desc">Diagramming from plain text. Fast. It works.</span>
          </div>
          <div class="resources-block__tool-row">
            <span class="t-mono resources-block__tool-name">Granola</span>
            <span class="resources-block__tool-desc">AI notetaker for discovery calls and syncs.</span>
          </div>
          <div class="resources-block__tool-row">
            <span class="t-mono resources-block__tool-name">Figma Make</span>
            <span class="resources-block__tool-desc">AI layer for UI components and mockups.</span>
          </div>
        </div>
        <span class="resources-block__link resources-block__link--coming">Full stack — coming soon</span>
      </div>

      <div class="resources-block">
        <div class="resources-block__num t-mono">03</div>
        <h2 class="resources-block__title">Resources I Recommend</h2>
        <p class="resources-block__body">Couldn't find it on my site? Try these.</p>
        <div class="resources-block__links">
          <a href="https://www.productmarketingalliance.com/" target="_blank" rel="noopener" class="resources-block__ext-link">
            Product Marketing Alliance
            <span class="resources-block__ext-desc">The #1 professional network for product marketers.</span>
          </a>
          <a href="https://thepmmcollective.com/collaborative-knowledge-hub/" target="_blank" rel="noopener" class="resources-block__ext-link">
            PMM Collective Knowledge Hub
            <span class="resources-block__ext-desc">Community-built reference for PMMs.</span>
          </a>
        </div>
      </div>

      <div class="resources-block">
        <div class="resources-block__num t-mono">04</div>
        <h2 class="resources-block__title">Free Mentoring</h2>
        <p class="resources-block__body">For product marketers and technical writers who need honest feedback and no agenda. No time limit. We start with one meeting and take it from there.</p>
        <a href="/get-help-free/" class="btn btn-voltage resources-block__cta">Learn more</a>
      </div>

    </div>
  </section>

</Base>

<style>
  .resources-hero {
    padding: 88px var(--pad-page) 64px;
    border-bottom: 1px solid var(--c-hairline-soft);
  }

  .resources-hero__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .resources-hero__eyebrow {
    color: var(--c-pink-hot);
    margin-bottom: 20px;
  }

  .resources-hero__h1 {
    font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 800;
    letter-spacing: -2px;
    color: var(--c-ink);
    margin: 0 0 20px;
  }

  .resources-hero__lede {
    font-size: 18px;
    line-height: 1.55;
    color: var(--c-body);
    max-width: 52ch;
    margin: 0;
  }

  .resources-grid {
    padding: 64px var(--pad-page) 96px;
  }

  .resources-grid__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--c-hairline-soft);
  }

  .resources-block {
    padding: 40px 32px 40px 0;
    border-right: 1px solid var(--c-hairline-soft);
    border-bottom: 1px solid var(--c-hairline-soft);
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
  }

  .resources-block:nth-child(even) {
    padding-left: 32px;
    padding-right: 0;
    border-right: none;
  }

  .resources-block:nth-child(3),
  .resources-block:nth-child(4) {
    border-bottom: none;
  }

  .resources-block__num {
    font-size: 12px;
    letter-spacing: 1px;
    color: var(--c-muted);
  }

  .resources-block__title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--c-ink);
    margin: 0;
  }

  .resources-block__body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-body);
    margin: 0;
  }

  .resources-block__link {
    font-size: 14px;
    font-weight: 600;
    color: var(--c-purple-royal);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--c-green-voltage);
    margin-top: auto;
  }

  .resources-block__link--coming {
    color: var(--c-muted);
    text-decoration: none;
    cursor: default;
  }

  .resources-block__recent {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid var(--c-hairline-soft);
    padding-top: 14px;
  }

  .resources-block__post {
    display: flex;
    gap: 12px;
    align-items: baseline;
  }

  .resources-block__date {
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--c-muted);
    white-space: nowrap;
  }

  .resources-block__post-title {
    font-size: 14px;
    color: var(--c-ink);
    line-height: 1.3;
  }

  .resources-block__tools {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid var(--c-hairline-soft);
    padding-top: 14px;
  }

  .resources-block__tool-row {
    display: flex;
    gap: 12px;
    align-items: baseline;
  }

  .resources-block__tool-name {
    font-size: 11px;
    letter-spacing: 0.5px;
    color: var(--c-muted);
    white-space: nowrap;
    min-width: 70px;
  }

  .resources-block__tool-desc {
    font-size: 14px;
    color: var(--c-body);
    line-height: 1.3;
  }

  .resources-block__links {
    display: flex;
    flex-direction: column;
    gap: 14px;
    border-top: 1px solid var(--c-hairline-soft);
    padding-top: 14px;
  }

  .resources-block__ext-link {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    color: var(--c-ink);
  }

  .resources-block__ext-link:hover {
    color: var(--c-purple-royal);
  }

  .resources-block__ext-desc {
    font-size: 13px;
    font-weight: 400;
    color: var(--c-muted);
  }

  .resources-block__cta {
    align-self: flex-start;
    margin-top: auto;
  }

  @media (max-width: 700px) {
    .resources-grid__inner {
      grid-template-columns: 1fr;
    }
    .resources-block,
    .resources-block:nth-child(even) {
      padding: 32px 0;
      border-right: none;
      border-bottom: 1px solid var(--c-hairline-soft);
    }
    .resources-block:last-child {
      border-bottom: none;
    }
  }
</style>
