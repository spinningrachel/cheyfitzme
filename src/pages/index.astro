---
import Base from '../layouts/Base.astro';
---

<Base
  title="Home"
  description="Deep-tech category-positioning lead. Turning un-marketable technology into a defensible market position before the cash runs out."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__content">
      <div class="t-label hero__eyebrow">Deep-tech category-positioning lead</div>
      <h1 class="hero__h1">Turning un-marketable technology into a defensible market position before the cash runs out.</h1>
      <p class="hero__lede">25 years across cybersecurity, AI/ML, developer tools, and enterprise. Most recently founding marketer at Visual Layer through our acquisition by Camtek. Before that: Director of Marketing at Coro — 13 reports, $1M+ quarterly ACV, 300% YoY growth — and Head of PMM at Lytx, where we lifted market share by 65%. Full stack, AI-leveraged, no handoff.</p>
      <div class="hero__ctas">
        <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}lets-meet/`} class="btn btn-voltage">Let's meet — it's free</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}portfolio/`} class="btn btn-text">See my work</a>
      </div>
    </div>
    <div class="hero__portrait">
      <img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}rachel-cheyfitz.jpg`} alt="Rachel Cheyfitz" class="hero__portrait-img" />
    </div>
  </section>

  <!-- PROOF STRIP -->
  <section class="proof">
    <div class="proof__inner">
      <div class="proof__grid">
        <div class="proof__item">
          <div class="proof__company">Visual Layer</div>
          <div class="proof__stat">Zero to acquisition &middot; ARR &lt;$1M &rarr; $3M</div>
          <div class="proof__context">Camtek, Nasdaq: CAMT &middot; Apr 2026</div>
        </div>
        <div class="proof__item">
          <div class="proof__company">Coro Cybersecurity</div>
          <div class="proof__stat">13 reports &middot; $1M+ quarterly ACV &middot; 300% YoY growth</div>
        </div>
        <div class="proof__item">
          <div class="proof__company">Lytx / Surfsight</div>
          <div class="proof__stat">+65% market share &middot; 300-page developer portal</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services">
    <div class="services__inner">
      <h2 class="services__heading">How I can help</h2>
      <div class="services__grid">
        <div class="services__col">
          <div class="services__num">01</div>
          <h3 class="services__title">Strategy &amp; Advisory</h3>
          <p class="services__body">Positioning frameworks, GTM strategy, and the analyst story that makes your category legible. The upstream work that determines whether everything downstream converts.</p>
          <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}positioning/`} class="services__link">See advisory</a>
        </div>
        <div class="services__col">
          <div class="services__num">02</div>
          <h3 class="services__title">Frameworks &amp; Positioning</h3>
          <p class="services__body">Express engagements that get to clarity fast — ICP definitions, messaging hierarchies, competitive positioning. Deliverables your team actually uses.</p>
          <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}positioning/`} class="services__link">See frameworks</a>
        </div>
        <div class="services__col">
          <div class="services__num">03</div>
          <h3 class="services__title">Resources &amp; Community</h3>
          <p class="services__body">The Marketing Leadership Stack, the Playbook, events, and free mentoring. Built for practitioners who want to think and work better.</p>
          <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}marketing-resources/`} class="services__link">Explore</a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW I WORK -->
  <section class="why">
    <div class="why__inner">
      <div class="t-label why__eyebrow">How I work</div>
      <div class="why__grid">
        <div class="why__col">
          <h3 class="why__title">Research first</h3>
          <p class="why__body">Market, ICP, competitive landscape — before a single word of messaging gets written. Strategy built on evidence, not instinct.</p>
        </div>
        <div class="why__col">
          <h3 class="why__title">Strategy and artifacts</h3>
          <p class="why__body">Positioning that ships as living documents, not slide decks that age. Frameworks your team inherits and actually uses.</p>
        </div>
        <div class="why__col">
          <h3 class="why__title">AI-architected leverage</h3>
          <p class="why__body">I build the workflows. Faster output without sacrificing the depth that makes positioning stick.</p>
        </div>
        <div class="why__col">
          <h3 class="why__title">Multi-vertical depth</h3>
          <p class="why__body">Cybersecurity, AI/ML, developer tools, fleet tech, enterprise SaaS. Pattern recognition that single-vertical practitioners don't have.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LOGO CAROUSEL -->
  <section class="logos">
    <div class="logos__inner">
      <div class="t-label logos__eyebrow">Customers &amp; employers</div>
    </div>
    <div class="logos__track-wrap" aria-hidden="true">
      <div class="logos__track">
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/surfsight.jpg`} alt="Lytx / Surfsight" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/snyk.png`} alt="Snyk" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/cisco.png`} alt="Cisco" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/fiverr.png`} alt="Fiverr" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/pentera.png`} alt="Pentera" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/incredibuild.jpg`} alt="Incredibuild" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/comeet.png`} alt="Comeet" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/reco.jpg`} alt="Reco" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/xmcyber.png`} alt="XM Cyber" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/lightrun.png`} alt="Lightrun" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/hysolate.png`} alt="Hysolate" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/blink.jpg`} alt="Blink" /></div>
        <!-- duplicate for seamless loop -->
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/surfsight.jpg`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/snyk.png`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/cisco.png`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/fiverr.png`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/pentera.png`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/incredibuild.jpg`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/comeet.png`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/reco.jpg`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/xmcyber.png`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/lightrun.png`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/hysolate.png`} alt="" /></div>
        <div class="logos__slot"><img src={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}logos/blink.jpg`} alt="" /></div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <div class="testimonials__inner">
      <blockquote class="testimonials__quote">
        Her confidence is uniquely needed at the right time and her passion is contagious. Rachel is a true asset to any organization — her ability to challenge the status quo is refreshing. If you want to succeed with high value returns, Rachel is who you want on your team.
      </blockquote>
      <cite class="testimonials__cite">Karen Torrenti — Customer First Champion, B2B SaaS</cite>
    </div>
    <div class="testimonials__senja">
      <script type="text/javascript" src="https://widget.senja.io/js/iframeResizer.min.js"></script>
      <iframe id="wall-of-love-gUuBAx4" src="https://senja.io/p/cheyfitz/gUuBAx4?hideNavigation=true&embed=true" title="Wall of Love" frameborder="0" scrolling="no" width="100%"></iframe>
      <script type="text/javascript">document.addEventListener("DOMContentLoaded", function () { iFrameResize({ log: false, checkOrigin: false }, "#wall-of-love-gUuBAx4"); });</script>
    </div>
  </section>

  <!-- VOLTAGE CTA BAND -->
  <section class="cta-band">
    <div class="cta-band__inner">
      <h2 class="cta-band__heading">Ready to make your product impossible to ignore?</h2>
      <div class="cta-band__actions">
        <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}lets-meet/`} class="btn btn-voltage">Let's meet — it's free</a>
        <a href={`${import.meta.env.BASE_URL.replace(/\/*$/, "/")}mentor/`} class="btn btn-ink">Free mentoring</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ─── HERO ─────────────────────────────────────────── */
  .hero {
    padding: 96px var(--pad-page) 64px;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 60px;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hero__eyebrow {
    color: var(--c-pink-hot);
    margin-bottom: 26px;
  }

  .hero__h1 {
    font-size: clamp(36px, 5.5vw, 62px);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -3px;
    color: var(--c-ink);
    margin: 0 0 26px;
    text-wrap: balance;
  }

  .hero__lede {
    font-size: 20px;
    line-height: 1.5;
    color: var(--c-body);
    max-width: 48ch;
    margin: 0 0 34px;
  }

  .hero__ctas {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero__portrait {
    aspect-ratio: 4/5;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--c-hairline-soft);
  }

  .hero__portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero__portrait-label {
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--c-muted-soft);
  }

  /* ─── PROOF STRIP ───────────────────────────────────── */
  .proof {
    border-top: 1px solid var(--c-hairline-soft);
    border-bottom: 1px solid var(--c-hairline-soft);
    padding: 0 var(--pad-page);
    margin-bottom: 88px;
  }

  .proof__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .proof__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .proof__item {
    padding: 28px 28px 28px 0;
    border-right: 1px solid var(--c-hairline-soft);
  }
  .proof__item:not(:first-child) {
    padding-left: 28px;
  }
  .proof__item:last-child {
    border-right: none;
    padding-right: 0;
  }

  .proof__company {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--c-ink);
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .proof__stat {
    font-size: 15px;
    font-weight: 600;
    color: var(--c-ink);
    line-height: 1.35;
    margin-bottom: 4px;
  }

  .proof__context {
    font-size: 12px;
    color: var(--c-muted-soft);
  }

  @media (max-width: 700px) {
    .proof__grid {
      grid-template-columns: 1fr;
    }
    .proof__item {
      border-right: none;
      border-bottom: 1px solid var(--c-hairline-soft);
      padding: 20px 0;
    }
    .proof__item:last-child {
      border-bottom: none;
    }
  }

  /* ─── SERVICES ──────────────────────────────────────── */
  .services {
    padding: 0 var(--pad-page) 88px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .services__heading {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.8px;
    color: var(--c-ink);
    margin: 0 0 40px;
    max-width: 30ch;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--c-hairline-soft);
  }

  .services__col {
    padding: 32px 32px 32px 0;
    border-right: 1px solid var(--c-hairline-soft);
  }
  .services__col:not(:first-child) {
    padding-left: 32px;
  }
  .services__col:last-child {
    border-right: none;
    padding-right: 0;
  }

  .services__num {
    font-size: 14px;
    font-weight: 700;
    color: var(--c-muted-soft);
    margin-bottom: 18px;
  }

  .services__title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--c-ink);
    margin: 0 0 10px;
  }

  .services__body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-body);
    margin: 0 0 18px;
  }

  .services__link {
    font-size: 15px;
    font-weight: 600;
    color: var(--c-ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--c-green-voltage);
  }
  .services__link:hover {
    color: var(--c-purple-royal);
  }

  /* ─── WHY ME ────────────────────────────────────────── */
  .why {
    padding: 0 var(--pad-page) 88px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .why__eyebrow {
    color: var(--c-pink);
    margin-bottom: 28px;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--c-hairline-soft);
  }

  .why__col {
    padding: 26px 22px 0 0;
    border-right: 1px solid var(--c-hairline-soft);
  }
  .why__col:not(:first-child) {
    padding-left: 22px;
  }
  .why__col:last-child {
    border-right: none;
    padding-right: 0;
  }

  .why__title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.4px;
    color: var(--c-ink);
    margin: 0 0 8px;
  }

  .why__body {
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-body);
    margin: 0;
  }

  /* ─── LOGO CAROUSEL ─────────────────────────────────── */
  .logos {
    background: var(--c-surface);
    border-top: 1px solid var(--c-hairline-soft);
    border-bottom: 1px solid var(--c-hairline-soft);
    padding: 48px 0 52px;
  }

  .logos__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--pad-page);
  }

  .logos__eyebrow {
    color: var(--c-muted-soft);
    margin-bottom: 28px;
  }

  .logos__track-wrap {
    overflow: hidden;
    position: relative;
  }
  .logos__track-wrap::before,
  .logos__track-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 1;
    pointer-events: none;
  }
  .logos__track-wrap::before {
    left: 0;
    background: linear-gradient(to right, var(--c-surface), transparent);
  }
  .logos__track-wrap::after {
    right: 0;
    background: linear-gradient(to left, var(--c-surface), transparent);
  }

  .logos__track {
    display: flex;
    align-items: center;
    gap: 52px;
    animation: logos-scroll 32s linear infinite;
    width: max-content;
  }
  .logos__track:hover {
    animation-play-state: paused;
  }

  @keyframes logos-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .logos__slot {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logos__slot img {
    height: 44px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
  }

  /* ─── TESTIMONIALS ──────────────────────────────────── */
  .testimonials {
    padding: 88px var(--pad-page);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testimonials__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testimonials__quote {
    font-size: clamp(22px, 2.5vw, 32px);
    line-height: 1.25;
    letter-spacing: -1px;
    color: var(--c-ink);
    font-weight: 500;
    margin: 0 0 24px;
  }

  .testimonials__cite {
    font-size: 15px;
    color: var(--c-body);
    font-style: normal;
  }

  .testimonials__senja {
    margin-top: 56px;
    padding: 0 var(--pad-page);
    max-width: var(--max-width);
    margin-left: auto;
    margin-right: auto;
  }

  /* ─── VOLTAGE CTA BAND ──────────────────────────────── */
  .cta-band {
    background: var(--c-ink);
    padding: 72px var(--pad-page);
  }

  .cta-band__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .cta-band__heading {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--c-white);
    margin: 0;
    max-width: 28ch;
  }

  .cta-band__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ─── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 56px;
    }
    .hero__portrait {
      aspect-ratio: 3/2;
      order: -1;
    }
    .services__grid,
    .why__grid {
      grid-template-columns: 1fr 1fr;
    }
    .services__col,
    .why__col {
      border-right: none;
      border-bottom: 1px solid var(--c-hairline-soft);
      padding: 24px 0;
    }
    .cta-band__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 560px) {
    .services__grid,
    .why__grid {
      grid-template-columns: 1fr;
    }
    .hero__h1 {
      letter-spacing: -2px;
    }
  }
</style>

