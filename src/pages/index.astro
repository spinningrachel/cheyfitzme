---
import Base from '../layouts/Base.astro';
---

<Base
  title="Home"
  description="Deep-tech category-positioning lead. Turning un-marketable technology into a defensible market position before the cash runs out."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__content">
      <div class="t-label hero__eyebrow">Marketing strategist, advisor &amp; mentor</div>
      <h1 class="hero__h1">Turning un-marketable technology into a defensible market position before the cash runs out.</h1>
      <p class="hero__lede">I'm not just solving the problem in front of you. I'm fixing the reason it keeps happening — the positioning and messaging architecture underneath.</p>
      <div class="hero__ctas">
        <a href="/lets-meet/" class="btn btn-voltage">Let's meet — it's free</a>
        <a href="/core-positioning/" class="btn btn-text">See how I can help</a>
      </div>
    </div>
    <div class="hero__portrait" aria-hidden="true">
      <span class="t-mono hero__portrait-label">your photo</span>
    </div>
  </section>

  <!-- ROTATING TAGLINE -->
  <section class="tagline-row">
    <div class="tagline-row__inner">
      <span class="tagline-row__static">I make your stuff</span>
      <ul class="tagline-row__rotate" role="list" aria-live="polite">
        <li class="tagline-row__item is-active">reach the right vertical</li>
        <li class="tagline-row__item">speak to the right persona</li>
        <li class="tagline-row__item">profitable for your partners</li>
        <li class="tagline-row__item">impossible to ignore</li>
      </ul>
      <div class="tagline-row__dots" aria-hidden="true">
        <span class="dot is-active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services">
    <div class="services__inner">
      <h2 class="services__heading">Three ways in. Each one fixes the architecture, not just the deliverable.</h2>
      <div class="services__grid">
        <div class="services__col">
          <div class="services__num">01</div>
          <h3 class="services__title">Strategy &amp; Advisory</h3>
          <p class="services__body">Positioning frameworks, GTM strategy, and the documentation infrastructure underneath them.</p>
          <a href="/core-positioning/" class="services__link">See advisory</a>
        </div>
        <div class="services__col">
          <div class="services__num">02</div>
          <h3 class="services__title">Frameworks &amp; Positioning</h3>
          <p class="services__body">Express engagements that get to clarity fast, without losing the depth that makes positioning stick.</p>
          <a href="/core-positioning/#frameworks" class="services__link">See frameworks</a>
        </div>
        <div class="services__col">
          <div class="services__num">03</div>
          <h3 class="services__title">Resources &amp; Community</h3>
          <p class="services__body">The PMM Stack, the Playbook, events, and free mentoring. The resources I wish I had had.</p>
          <a href="/marketing-resources/" class="services__link">Explore</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY WORK WITH ME -->
  <section class="why">
    <div class="why__inner">
      <div class="t-label why__eyebrow">Why work with me</div>
      <div class="why__grid">
        <div class="why__col">
          <h3 class="why__title">Global market expertise</h3>
          <p class="why__body">Deep tech to consumer, B2B, B2D and B2C. I have shipped in all of them.</p>
        </div>
        <div class="why__col">
          <h3 class="why__title">Scalable frameworks</h3>
          <p class="why__body">Systems your team keeps using long after I am gone.</p>
        </div>
        <div class="why__col">
          <h3 class="why__title">Engaging storytelling</h3>
          <p class="why__body">Technical truth, told so people actually want to read it.</p>
        </div>
        <div class="why__col">
          <h3 class="why__title">Knowledge sharing</h3>
          <p class="why__body">A mentor by default. I leave teams sharper than I found them.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LOGO WALL -->
  <section class="logos">
    <div class="logos__inner">
      <div class="t-label logos__eyebrow">Customers &amp; employers</div>
      <div class="logos__grid">
        <!-- Replace placeholders with real SVG/img logos -->
        <div class="logos__slot" aria-label="Coro Cybersecurity"></div>
        <div class="logos__slot" aria-label="Lytx / Surfsight"></div>
        <div class="logos__slot" aria-label="Snyk"></div>
        <div class="logos__slot" aria-label="Visual Layer"></div>
        <div class="logos__slot" aria-label="Fiverr"></div>
        <div class="logos__slot" aria-label="Cisco"></div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <div class="testimonials__inner">
      <div class="testimonials__featured">
        <blockquote class="testimonials__quote">
          She rebuilt our positioning in three weeks. The messaging still holds two years later.
        </blockquote>
        <cite class="testimonials__cite">VP Marketing, Series B SaaS</cite>
        <div class="testimonials__secondary rule-top">
          <p class="testimonials__secondary-quote">The clearest strategic thinker I have worked with. No fluff, all signal.</p>
          <cite class="testimonials__secondary-cite">Founder, Dev tools</cite>
        </div>
      </div>
      <div class="testimonials__embed">
        <span class="t-mono testimonials__embed-label">embed · senja.io</span>
        <p class="testimonials__embed-note">Senja testimonial wall — drop iframe here when account is ready.</p>
        <!-- <iframe src="https://senja.io/p/your-widget-id" ... /> -->
      </div>
    </div>
  </section>

  <!-- VOLTAGE CTA BAND -->
  <section class="cta-band">
    <div class="cta-band__inner">
      <h2 class="cta-band__heading">Ready to make your product impossible to ignore?</h2>
      <div class="cta-band__actions">
        <a href="/lets-meet/" class="btn btn-voltage">Let's meet — it's free</a>
        <a href="/get-help-free/" class="btn btn-ink">Free mentoring</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ─── HERO ─────────────────────────────────────────── */
  .hero {
    padding: 96px var(--pad-page) 64px;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 60px;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hero__eyebrow {
    color: var(--c-pink-hot);
    margin-bottom: 26px;
  }

  .hero__h1 {
    font-size: clamp(36px, 5.5vw, 62px);
    font-weight: 800;
    line-height: 0.98;
    letter-spacing: -3px;
    color: var(--c-ink);
    margin: 0 0 26px;
    text-wrap: balance;
  }

  .hero__lede {
    font-size: 20px;
    line-height: 1.5;
    color: var(--c-body);
    max-width: 48ch;
    margin: 0 0 34px;
  }

  .hero__ctas {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero__portrait {
    aspect-ratio: 4/5;
    border-radius: 14px;
    background: var(--c-surface);
    border: 1px solid var(--c-hairline-soft);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 20px;
  }

  .hero__portrait-label {
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--c-muted-soft);
  }

  /* ─── ROTATING TAGLINE ──────────────────────────────── */
  .tagline-row {
    padding: 0 var(--pad-page) 88px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .tagline-row__inner {
    border-top: 1px solid var(--c-hairline-soft);
    padding-top: 22px;
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
  }

  .tagline-row__static {
    font-size: 17px;
    font-weight: 600;
    color: var(--c-ink);
    white-space: nowrap;
  }

  .tagline-row__rotate {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: baseline;
  }

  .tagline-row__item {
    font-size: 17px;
    font-weight: 600;
    color: var(--c-muted-soft);
    transition: color 0.3s;
  }

  .tagline-row__item.is-active {
    color: var(--c-ink);
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-color: var(--c-green-voltage);
  }

  .tagline-row__dots {
    margin-left: auto;
    display: flex;
    gap: 6px;
    align-self: center;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-hairline-soft);
    transition: background 0.3s;
  }
  .dot.is-active {
    background: var(--c-ink);
  }

  /* ─── SERVICES ──────────────────────────────────────── */
  .services {
    padding: 0 var(--pad-page) 88px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .services__heading {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.8px;
    color: var(--c-ink);
    margin: 0 0 40px;
    max-width: 30ch;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--c-hairline-soft);
  }

  .services__col {
    padding: 32px 32px 32px 0;
    border-right: 1px solid var(--c-hairline-soft);
  }
  .services__col:not(:first-child) {
    padding-left: 32px;
  }
  .services__col:last-child {
    border-right: none;
    padding-right: 0;
  }

  .services__num {
    font-size: 14px;
    font-weight: 700;
    color: var(--c-muted-soft);
    margin-bottom: 18px;
  }

  .services__title {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--c-ink);
    margin: 0 0 10px;
  }

  .services__body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-body);
    margin: 0 0 18px;
  }

  .services__link {
    font-size: 15px;
    font-weight: 600;
    color: var(--c-ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--c-green-voltage);
  }
  .services__link:hover {
    color: var(--c-purple-royal);
  }

  /* ─── WHY ME ────────────────────────────────────────── */
  .why {
    padding: 0 var(--pad-page) 88px;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .why__eyebrow {
    color: var(--c-pink);
    margin-bottom: 28px;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--c-hairline-soft);
  }

  .why__col {
    padding: 26px 22px 0 0;
    border-right: 1px solid var(--c-hairline-soft);
  }
  .why__col:not(:first-child) {
    padding-left: 22px;
  }
  .why__col:last-child {
    border-right: none;
    padding-right: 0;
  }

  .why__title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.4px;
    color: var(--c-ink);
    margin: 0 0 8px;
  }

  .why__body {
    font-size: 14px;
    line-height: 1.5;
    color: var(--c-body);
    margin: 0;
  }

  /* ─── LOGO WALL ─────────────────────────────────────── */
  .logos {
    background: var(--c-surface);
    border-top: 1px solid var(--c-hairline-soft);
    padding: 56px var(--pad-page);
  }

  .logos__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .logos__eyebrow {
    color: var(--c-muted-soft);
    margin-bottom: 30px;
  }

  .logos__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 28px 36px;
    align-items: center;
    opacity: 0.55;
  }

  .logos__slot {
    height: 18px;
    background: var(--c-ink);
    border-radius: 3px;
  }
  .logos__slot:nth-child(2) { width: 78%; }
  .logos__slot:nth-child(4) { width: 70%; }
  .logos__slot:nth-child(6) { width: 84%; }

  /* ─── TESTIMONIALS ──────────────────────────────────── */
  .testimonials {
    padding: 88px var(--pad-page);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testimonials__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .testimonials__quote {
    font-size: clamp(22px, 2.5vw, 32px);
    line-height: 1.25;
    letter-spacing: -1px;
    color: var(--c-ink);
    font-weight: 500;
    margin: 0 0 24px;
    max-width: 22ch;
  }

  .testimonials__cite {
    font-size: 15px;
    color: var(--c-body);
    font-style: normal;
  }

  .testimonials__secondary {
    margin-top: 36px;
    padding-top: 24px;
  }

  .testimonials__secondary-quote {
    font-size: 18px;
    line-height: 1.4;
    color: var(--c-ink);
    margin: 0 0 10px;
  }

  .testimonials__secondary-cite {
    font-size: 14px;
    color: var(--c-muted-soft);
    font-style: normal;
  }

  .testimonials__embed {
    border: 1px dashed var(--c-hairline-soft);
    border-radius: 12px;
    padding: 28px;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .testimonials__embed-label {
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--c-muted-soft);
    margin-bottom: 8px;
    display: block;
  }

  .testimonials__embed-note {
    font-size: 15px;
    line-height: 1.5;
    color: var(--c-body);
    margin: 0;
  }

  /* ─── VOLTAGE CTA BAND ──────────────────────────────── */
  .cta-band {
    background: var(--c-ink);
    padding: 72px var(--pad-page);
  }

  .cta-band__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .cta-band__heading {
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--c-white);
    margin: 0;
    max-width: 28ch;
  }

  .cta-band__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ─── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 56px;
    }
    .hero__portrait {
      aspect-ratio: 3/2;
      order: -1;
    }
    .services__grid,
    .why__grid {
      grid-template-columns: 1fr 1fr;
    }
    .services__col,
    .why__col {
      border-right: none;
      border-bottom: 1px solid var(--c-hairline-soft);
      padding: 24px 0;
    }
    .testimonials__inner {
      grid-template-columns: 1fr;
    }
    .logos__grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .cta-band__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 560px) {
    .services__grid,
    .why__grid {
      grid-template-columns: 1fr;
    }
    .logos__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .hero__h1 {
      letter-spacing: -2px;
    }
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.tagline-row__item');
  const dots = document.querySelectorAll<HTMLElement>('.dot');
  let current = 0;

  if (items.length > 1) {
    setInterval(() => {
      items[current].classList.remove('is-active');
      dots[current].classList.remove('is-active');
      current = (current + 1) % items.length;
      items[current].classList.add('is-active');
      dots[current].classList.add('is-active');
    }, 2600);
  }
</script>
